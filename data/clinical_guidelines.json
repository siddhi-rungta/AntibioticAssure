  "diagnosis_to_antibiotic": {
    "common_cold": {
      "requires_antibiotic": false,
      "reason": "Viral infection, antibiotics not indicated"
    },
    "influenza": {
      "requires_antibiotic": false,
      "reason": "Viral infection, antibiotics not indicated unless secondary bacterial infection"
    },
    "acute_bronchitis": {
      "requires_antibiotic": false,
      "reason": "Usually viral, antibiotics rarely needed"
    },
    "streptococcal_pharyngitis": {
      "requires_antibiotic": true,
      "first_line": ["amoxicillin", "penicillin"],
      "alternative": ["azithromycin", "cephalexin"]
    },
    "community_acquired_pneumonia": {
      "requires_antibiotic": true,
      "first_line": ["amoxicillin", "azithromycin"],
      "severe_cases": ["ceftriaxone", "levofloxacin"]
    },
    "urinary_tract_infection": {
      "requires_antibiotic": true,
      "first_line": ["nitrofurantoin", "trimethoprim-sulfamethoxazole"],
      "alternative": ["ciprofloxacin"],
      "complicated": ["ciprofloxacin", "levofloxacin"]
    },
    "acute_otitis_media": {
      "requires_antibiotic": true,
      "first_line": ["amoxicillin", "penicillin"],
      "alternative": ["azithromycin"]
    },
    "skin_infection": {
      "requires_antibiotic": true,
      "first_line": ["cephalexin", "dicloxacillin"],
      "mrsa_suspected": ["doxycycline", "trimethoprim-sulfamethoxazole"]
    }
  },
  "stewardship_rules": {
    "avoid_broad_spectrum_for_simple_infections": {
      "description": "Use narrow-spectrum antibiotics for uncomplicated infections",
      "broad_spectrum_antibiotics": ["ciprofloxacin", "levofloxacin", "ceftriaxone", "azithromycin"]
    },
    "duration_limits": {
      "description": "Avoid unnecessarily long antibiotic courses",
      "typical_max_days": 14,
      "exceptions": ["endocarditis", "osteomyelitis", "tuberculosis"]
    },
    "no_antibiotics_for_viral": {
      "description": "Do not prescribe antibiotics for viral infections",
      "viral_diagnoses": ["common_cold", "influenza", "viral_pharyngitis", "acute_bronchitis"]
    }
  }
